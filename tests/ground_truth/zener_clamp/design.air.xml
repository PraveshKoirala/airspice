<system name="gt_zener_clamp" ir_version="0.1">
  <metadata>
    <title>Expected-failure (#55): Zener clamp voltage</title>
    <description>A 5.1V Zener fed reverse-biased through a series resistor should clamp its cathode near the breakdown voltage BV=5.1V. Modeling reverse breakdown requires a diode model with a BV parameter (spice_model=ZENER_5V1). The compiler emits the device line but no matching .model card, so ngspice cannot simulate -> DC fallback. Captured as expected-failure linked to #55.</description>
    <author>issue-41</author>
  </metadata>
  <nets>
    <net id="gnd" role="ground"/>
    <net id="vin" role="power" nominal_voltage="12V"/>
    <net id="clamp" role="analog_signal"/>
  </nets>
  <components>
    <component id="V_IN" type="voltage_source">
      <value>12V</value>
      <pin name="p" net="vin"/>
      <pin name="n" net="gnd"/>
    </component>
    <component id="R_S" type="resistor">
      <value>1k</value>
      <pin name="1" net="vin"/>
      <pin name="2" net="clamp"/>
    </component>
    <component id="D_Z" type="diode" spice_model="ZENER_5V1">
      <pin name="a" net="gnd"/>
      <pin name="c" net="clamp"/>
    </component>
  </components>
  <analog>
    <subsystem id="zener">
      <uses component="V_IN"/>
      <uses component="R_S"/>
      <uses component="D_Z"/>
      <probe id="probe_clamp" net="clamp" quantity="voltage"/>
    </subsystem>
  </analog>
  <tests>
    <test id="zener_clamp">
      <run duration="1ms"/>
      <assert_voltage net="clamp" min="4.9V" max="5.3V"/>
    </test>
  </tests>
  <simulation_profiles>
    <profile id="analog_only" default="true">
      <backend type="ngspice"/>
      <include subsystem="zener"/>
      <run test="zener_clamp"/>
    </profile>
  </simulation_profiles>
</system>
