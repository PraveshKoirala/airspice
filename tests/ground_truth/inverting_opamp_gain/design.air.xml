<system name="gt_inverting_opamp_gain" ir_version="0.1">
  <metadata>
    <title>Expected-failure (#55): inverting op-amp gain -Rf/Rin</title>
    <description>Classic inverting amplifier: Vin through Rin to the virtual-ground inverting input, Rf feedback, non-inverting input grounded. Ideal gain is -Rf/Rin. AIR has no op-amp primitive the compiler can emit with a defined model; using spice_subckt=OPAMP_IDEAL emits an X-line referencing a subckt that is never defined, so ngspice cannot run -> DC fallback. Captured as expected-failure linked to #55.</description>
    <author>issue-41</author>
  </metadata>
  <nets>
    <net id="gnd" role="ground"/>
    <net id="vin" role="power" nominal_voltage="1V"/>
    <net id="inv" role="analog_signal"/>
    <net id="vout" role="analog_signal"/>
  </nets>
  <components>
    <component id="V_IN" type="voltage_source">
      <value>1V</value>
      <pin name="p" net="vin"/>
      <pin name="n" net="gnd"/>
    </component>
    <component id="R_IN" type="resistor">
      <value>10k</value>
      <pin name="1" net="vin"/>
      <pin name="2" net="inv"/>
    </component>
    <component id="R_F" type="resistor">
      <value>22k</value>
      <pin name="1" net="inv"/>
      <pin name="2" net="vout"/>
    </component>
    <component id="U_OA" type="opamp" spice_subckt="OPAMP_IDEAL">
      <pin name="inp" net="gnd"/>
      <pin name="inn" net="inv"/>
      <pin name="out" net="vout"/>
    </component>
  </components>
  <analog>
    <subsystem id="amp">
      <uses component="V_IN"/>
      <uses component="R_IN"/>
      <uses component="R_F"/>
      <uses component="U_OA"/>
      <probe id="probe_vout" net="vout" quantity="voltage"/>
    </subsystem>
  </analog>
  <tests>
    <test id="inv_gain">
      <run duration="1ms"/>
      <assert_voltage net="vout" min="-2.31V" max="-2.09V"/>
    </test>
  </tests>
  <simulation_profiles>
    <profile id="analog_only" default="true">
      <backend type="ngspice"/>
      <include subsystem="amp"/>
      <run test="inv_gain"/>
    </profile>
  </simulation_profiles>
</system>
