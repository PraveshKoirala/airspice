<system name="gt_pwm_rc_average" ir_version="0.1">
  <metadata>
    <title>Ground truth: PWM + RC average voltage vs duty cycle</title>
    <description>A 100kHz, 50%-duty MCU PWM GPIO feeds an RC low-pass (tau=1ms &gt;&gt; PWM period 10us). After settling the capacitor sits at the duty-weighted average of the 3.3V logic swing = D*Vstep. R=10k, C=100nF.</description>
    <author>issue-41</author>
  </metadata>
  <nets>
    <net id="gnd" role="ground"/>
    <net id="v3v3" role="power" nominal_voltage="3.3V"/>
    <net id="pwm" role="digital_signal"/>
    <net id="avg" role="analog_signal"/>
  </nets>
  <components>
    <component id="V_3V3" type="voltage_source">
      <value>3.3V</value>
      <pin name="p" net="v3v3"/>
      <pin name="n" net="gnd"/>
    </component>
    <component id="U_MCU" type="mcu" part="ESP32-C3">
      <pin name="3V3" net="v3v3"/>
      <pin name="GND" net="gnd"/>
      <pin name="GPIO2" net="pwm" function="GPIO_OUT"/>
    </component>
    <component id="R_F" type="resistor">
      <value>10k</value>
      <pin name="1" net="pwm"/>
      <pin name="2" net="avg"/>
    </component>
    <component id="C_F" type="capacitor">
      <value>100nF</value>
      <pin name="1" net="avg"/>
      <pin name="2" net="gnd"/>
    </component>
  </components>
  <firmware>
    <project id="fw_main" target="U_MCU" framework="platformio" language="cpp">
      <board>esp32-c3-devkitm-1</board>
      <source_tree path="firmware/"/>
    </project>
    <task id="pwm_50" target="fw_main">
      <period>10us</period>
      <write_gpio pin="GPIO2" value="high"/>
      <delay duration="5us"/>
      <write_gpio pin="GPIO2" value="low"/>
    </task>
  </firmware>
  <analog>
    <subsystem id="lpf">
      <uses component="R_F"/>
      <uses component="C_F"/>
      <probe id="probe_avg" net="avg" quantity="voltage"/>
    </subsystem>
  </analog>
  <tests>
    <test id="pwm_avg">
      <run duration="10ms"/>
      <assert_voltage net="avg" min="0V" max="3.3V"/>
    </test>
  </tests>
  <simulation_profiles>
    <profile id="analog_only" default="true">
      <backend type="ngspice"/>
      <include subsystem="lpf"/>
      <run test="pwm_avg"/>
    </profile>
  </simulation_profiles>
</system>
