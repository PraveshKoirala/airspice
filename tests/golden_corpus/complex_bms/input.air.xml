<system name="complex_bms" ir_version="0.1">
  <metadata>
    <title>Complex Battery Management System</title>
    <description>A multi-stage LiPo charger with CC/CV logic implemented in C++.</description>
    <author>Test Suite</author>
    <created_at>2026-06-06</created_at>
  </metadata>

  <nets>
    <net id="gnd" role="ground"/>
    <net id="v_in" role="power" nominal_voltage="5V"/>
    <net id="v_3v3" role="power" nominal_voltage="3.3V"/>
    <net id="bat" role="power" nominal_voltage="3.7V"/>
    <net id="charge_ctrl" role="analog_signal"/>
    <net id="bat_sense" role="analog_signal"/>
  </nets>

  <components>
    <component id="MCU" type="mcu" part="ESP32-C3">
      <pin name="GPIO0" net="bat_sense" function="ADC1_CH0"/>
      <pin name="GPIO1" net="charge_ctrl" function="GPIO_OUT"/>
      <pin name="3V3" net="v_3v3"/>
      <pin name="GND" net="gnd"/>
    </component>

    <component id="U_REG" type="ldo" part="generic_3v3">
      <pin name="in" net="v_in"/>
      <pin name="out" net="v_3v3"/>
      <pin name="gnd" net="gnd"/>
      <property name="vout" value="3.3V"/>
      <property name="iout_max" value="500mA"/>
      <property name="v_dropout" value="0.2V"/>
      <property name="iq" value="10uA"/>
    </component>

    <component id="V_SUPPLY" type="voltage_source">
      <value>5V</value>
      <pin name="p" net="v_in"/>
      <pin name="n" net="gnd"/>
    </component>

    <component id="Q_CHG" type="mosfet" part="bss138">
      <pin name="G" net="charge_ctrl"/>
      <pin name="D" net="v_in"/>
      <pin name="S" net="bat"/>
    </component>

    <component id="R_SENSE_TOP" type="resistor">
      <value>100k</value>
      <pin name="1" net="bat"/>
      <pin name="2" net="bat_sense"/>
    </component>

    <component id="R_SENSE_BOT" type="resistor">
      <value>100k</value>
      <pin name="1" net="bat_sense"/>
      <pin name="2" net="gnd"/>
    </component>

    <component id="C_BAT" type="capacitor">
      <value>1000uF</value>
      <pin name="1" net="bat"/>
      <pin name="2" net="gnd"/>
    </component>
  </components>

  <firmware>
    <project id="bms_fw" target="MCU" framework="arduino" source_tree="tests/capability_suite/firmware">
      <board>esp32-c3-devkitm-1</board>
    </project>
    <binding id="bat_v_sense">
      <signal name="battery_voltage"/>
      <component ref="MCU"/>
      <peripheral>ADC1</peripheral>
      <channel>ADC1_CH0</channel>
      <net>bat_sense</net>
    </binding>
  </firmware>

  <analog>
    <subsystem id="charging_loop">
      <uses component="Q_CHG"/>
      <uses component="C_BAT"/>
      <probe id="p_bat" net="bat" quantity="voltage"/>
      <probe id="p_ctrl" net="charge_ctrl" quantity="voltage"/>
    </subsystem>
  </analog>

  <tests>
    <test id="charge_cycle">
      <setup>
        <set_voltage net="bat" value="3.0V"/>
      </setup>
      <run duration="1s"/>
      <assert_voltage net="bat" min="3.0V" max="4.3V"/>
    </test>
  </tests>

  <simulation_profiles>
    <profile id="full_verify" default="true">
      <backend type="ngspice"/>
      <include subsystem="charging_loop"/>
      <run test="charge_cycle"/>
      <properties>
        <property name="co_sim_mode" value="lockstep"/>
        <property name="time_step" value="1ms"/>
      </properties>
    </profile>
  </simulation_profiles>
</system>
