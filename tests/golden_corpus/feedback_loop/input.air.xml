<system name="feedback_loop_test" ir_version="0.1">
  <metadata>
    <title>High-Speed Feedback Loop Test</title>
    <description>Simulating a scenario where slow co-simulation fails (e.g., motor controller or fast regulator).</description>
  </metadata>
  <nets>
    <net id="gnd" role="ground"/>
    <net id="v_in" role="power" nominal_voltage="12V"/>
    <net id="v_out" role="power"/>
    <net id="ctrl" role="digital_signal"/>
  </nets>
  <components>
    <component id="V_IN" type="voltage_source">
      <value>12V</value>
      <pin name="p" net="v_in"/><pin name="n" net="gnd"/>
    </component>
    <!-- MOSFET switching a load to regulate output via high-speed PWM -->
    <component id="Q_SW" type="mosfet" spice_model="BSS138">
      <pin name="G" net="ctrl"/><pin name="D" net="v_in"/><pin name="S" net="v_out"/>
    </component>
    <component id="C_FILTER" type="capacitor">
      <value>10uF</value>
      <pin name="1" net="v_out"/><pin name="2" net="gnd"/>
    </component>
    <component id="L_LOAD" type="generic_load">
      <value>100mA</value>
      <pin name="p" net="v_out"/><pin name="n" net="gnd"/>
    </component>
    <component id="U_MCU" type="mcu" part="ESP32-C3">
      <pin name="3V3" net="v_in"/> <!-- Simplification -->
      <pin name="GND" net="gnd"/>
      <pin name="GPIO2" net="ctrl" function="GPIO_OUT"/>
      <pin name="GPIO0" net="v_out" function="ADC1_CH0"/>
    </component>
  </components>
  <firmware>
    <project id="fw" target="U_MCU" framework="platformio" language="cpp">
      <board>esp32-c3-devkitm-1</board>
    </project>
    <task id="pid_loop" target="fw">
      <period>100us</period> <!-- 10kHz loop! Serial co-sim will fail to track this -->
      <read_adc binding="out_sense" into="val"/>
      <write_gpio pin="GPIO2" value="high"/> <!-- PWM logic -->
    </task>
    <binding id="out_sense">
      <component ref="U_MCU"/><peripheral>ADC1</peripheral><channel>ADC1_CH0</channel><net>v_out</net>
    </binding>
  </firmware>
  <bridges>
    <bridge id="b1" type="adc">
      <analog_source net="v_out"/>
      <digital_target component="U_MCU" peripheral="ADC1" channel="ADC1_CH0"/>
    </bridge>
  </bridges>
  <tests>
    <test id="fast_regulation">
      <run duration="10ms"/>
      <assert_voltage net="v_out" min="4.5V" max="5.5V"/>
    </test>
  </tests>
  <simulation_profiles>
    <profile id="lockstep_sim" default="true">
      <backend type="ngspice"/>
      <backend type="renode"/>
      <run test="fast_regulation"/>
      <property name="co_sim_mode" value="lockstep"/>
      <property name="time_step" value="100us"/>
    </profile>
  </simulation_profiles>
</system>
