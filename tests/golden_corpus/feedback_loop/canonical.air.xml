<?xml version="1.0" ?>
<system ir_version="0.1" name="feedback_loop_test">
  <metadata>
    <title>High-Speed Feedback Loop Test</title>
    <description>Simulating a scenario where slow co-simulation fails (e.g., motor controller or fast regulator).</description>
  </metadata>
  <nets>
    <net id="ctrl" role="digital_signal"/>
    <net id="gnd" role="ground"/>
    <net id="v_in" nominal_voltage="12V" role="power"/>
    <net id="v_out" role="power"/>
  </nets>
  <components>
    <component id="C_FILTER" type="capacitor">
      <value>10uF</value>
      <pin name="1" net="v_out"/>
      <pin name="2" net="gnd"/>
    </component>
    <component id="L_LOAD" type="generic_load">
      <value>100mA</value>
      <pin name="p" net="v_out"/>
      <pin name="n" net="gnd"/>
    </component>
    <component id="Q_SW" spice_model="BSS138" type="mosfet">
      <pin name="G" net="ctrl"/>
      <pin name="D" net="v_in"/>
      <pin name="S" net="v_out"/>
    </component>
    <component id="U_MCU" part="ESP32-C3" type="mcu">
      <pin name="3V3" net="v_in"/>
      <pin name="GND" net="gnd"/>
      <pin function="GPIO_OUT" name="GPIO2" net="ctrl"/>
      <pin function="ADC1_CH0" name="GPIO0" net="v_out"/>
    </component>
    <component id="V_IN" type="voltage_source">
      <value>12V</value>
      <pin name="p" net="v_in"/>
      <pin name="n" net="gnd"/>
    </component>
  </components>
  <firmware>
    <project framework="platformio" id="fw" language="cpp" target="U_MCU">
      <board>esp32-c3-devkitm-1</board>
    </project>
    <task id="pid_loop" target="fw">
      <period>100us</period>
      <read_adc binding="out_sense" into="val"/>
      <write_gpio pin="GPIO2" value="high"/>
    </task>
    <binding id="out_sense">
      <component ref="U_MCU"/>
      <peripheral>ADC1</peripheral>
      <channel>ADC1_CH0</channel>
      <net>v_out</net>
    </binding>
  </firmware>
  <bridges>
    <bridge id="b1" type="adc">
      <analog_source net="v_out"/>
      <digital_target channel="ADC1_CH0" component="U_MCU" peripheral="ADC1"/>
    </bridge>
  </bridges>
  <tests>
    <test id="fast_regulation">
      <run duration="10ms"/>
      <assert_voltage max="5.5V" min="4.5V" net="v_out"/>
    </test>
  </tests>
  <simulation_profiles>
    <profile default="true" id="lockstep_sim">
      <backend type="ngspice"/>
      <backend type="renode"/>
      <run test="fast_regulation"/>
      <property name="co_sim_mode" value="lockstep"/>
      <property name="time_step" value="100us"/>
    </profile>
  </simulation_profiles>
</system>
