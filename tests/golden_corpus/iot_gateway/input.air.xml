<system name="iot_gateway" ir_version="0.1">
  <metadata>
    <title>Battery-Backed IoT Gateway</title>
    <description>Complex mixed-signal gateway with nested power domains, high-current load switching, and level-shifted I2C.</description>
  </metadata>

  <nets>
    <net id="gnd" role="ground"/>
    <net id="v_ext" role="power" nominal_voltage="12V"/>
    <net id="v_bat" role="power" nominal_voltage="3.7V"/>
    <net id="v_3v3" role="power" nominal_voltage="3.3V"/>
    <net id="v_1v8" role="power" nominal_voltage="1.8V"/>
    
    <net id="bat_sense" role="analog_signal"/>
    <net id="radio_en" role="digital_signal"/>
    <net id="radio_high" role="analog_signal"/>
    
    <net id="sda_3v3" role="digital_signal"/>
    <net id="scl_3v3" role="digital_signal"/>
    <net id="sda_1v8" role="digital_signal"/>
    <net id="scl_1v8" role="digital_signal"/>
  </nets>

  <components>
    <!-- Primary Power -->
    <component id="V_EXT" type="voltage_source">
      <value>12V</value>
      <pin name="p" net="v_ext"/>
      <pin name="n" net="gnd"/>
      <property name="i_max" value="1A"/>
    </component>

    <!-- Charger & Path Management (Subcircuit) -->
    <component id="X_CHARGER" type="power_manager" spice_subckt="MCP73831">
      <pin name="VIN" net="v_ext"/>
      <pin name="VBAT" net="v_bat"/>
      <pin name="GND" net="gnd"/>
    </component>

    <!-- Nested Regulators -->
    <component id="U_REG_3V3" type="ldo">
      <pin name="in" net="v_bat"/>
      <pin name="out" net="v_3v3"/>
      <pin name="gnd" net="gnd"/>
      <property name="vout" value="3.3V"/>
      <property name="iout_max" value="600mA"/>
      <property name="v_dropout" value="0.15V"/>
      <property name="iq" value="50uA"/>
    </component>

    <component id="U_REG_1V8" type="ldo">
      <pin name="in" net="v_3v3"/>
      <pin name="out" net="v_1v8"/>
      <pin name="gnd" net="gnd"/>
      <property name="vout" value="1.8V"/>
      <property name="iout_max" value="150mA"/>
      <property name="v_dropout" value="0.1V"/>
      <property name="iq" value="25uA"/>
    </component>

    <!-- MCU -->
    <component id="U_MCU" type="mcu" part="ESP32-C3">
      <pin name="3V3" net="v_3v3"/>
      <pin name="GND" net="gnd"/>
      <pin name="GPIO0" net="bat_sense" function="ADC1_CH0"/>
      <pin name="GPIO1" net="radio_en" function="GPIO_OUT"/>
      <pin name="GPIO8" net="sda_3v3" function="I2C_SDA"/>
      <pin name="GPIO9" net="scl_3v3" function="I2C_SCL"/>
    </component>

    <!-- High-Current Load Switch (Radio) -->
    <component id="Q_RADIO_GATE" type="mosfet" spice_model="BSS138">
      <pin name="G" net="radio_en"/>
      <pin name="D" net="radio_high"/>
      <pin name="S" net="gnd"/>
    </component>

    <component id="L_RADIO" type="generic_load">
      <value>400mA</value>
      <pin name="p" net="v_3v3"/>
      <pin name="n" net="radio_high"/>
    </component>

    <!-- 1.8V I2C Sensor (Subcircuit) -->
    <component id="X_SENSOR" type="sensor" spice_subckt="BME280">
      <pin name="VDD" net="v_1v8"/>
      <pin name="SDA" net="sda_1v8"/>
      <pin name="SCL" net="scl_1v8"/>
      <pin name="GND" net="gnd"/>
    </component>

    <!-- I2C Level Shifter (Discrete MOSFET implementation) -->
    <component id="Q_SDA_SHIFT" type="mosfet" spice_model="BSS138">
      <pin name="S" net="sda_1v8"/>
      <pin name="G" net="v_1v8"/>
      <pin name="D" net="sda_3v3"/>
    </component>
    <component id="Q_SCL_SHIFT" type="mosfet" spice_model="BSS138">
      <pin name="S" net="scl_1v8"/>
      <pin name="G" net="v_1v8"/>
      <pin name="D" net="scl_3v3"/>
    </component>

    <!-- Battery Monitor Divider -->
    <component id="R_BAT_HI" type="resistor">
      <value>1M</value>
      <pin name="1" net="v_bat"/>
      <pin name="2" net="bat_sense"/>
    </component>
    <component id="R_BAT_LO" type="resistor">
      <value>470k</value>
      <pin name="1" net="bat_sense"/>
      <pin name="2" net="gnd"/>
    </component>
  </components>

  <interfaces>
    <interface id="i2c_internal" type="i2c">
      <controller component="U_MCU" peripheral="I2C0"/>
      <sda net="sda_3v3"/>
      <scl net="scl_3v3"/>
      <!-- Pullups on 3.3V side -->
      <pullup net="sda_3v3" value="4.7k" to="v_3v3"/>
      <pullup net="scl_3v3" value="4.7k" to="v_3v3"/>
      <property name="speed" value="400kHz"/>
    </interface>
  </interfaces>

  <firmware>
    <project id="fw_main" target="U_MCU" framework="platformio" language="cpp">
      <board>esp32-c3-devkitm-1</board>
    </project>
    
    <task id="gateway_loop" target="fw_main">
      <period>500ms</period>
      <read_adc binding="bat_adc" into="v_bat_raw"/>
      <!-- Enable radio for transmit -->
      <write_gpio pin="GPIO1" value="high"/>
      <delay duration="50ms"/>
      <write_gpio pin="GPIO1" value="low"/>
    </task>

    <binding id="bat_adc">
      <component ref="U_MCU"/>
      <peripheral>ADC1</peripheral>
      <channel>ADC1_CH0</channel>
      <net>bat_sense</net>
    </binding>
  </firmware>

  <bridges>
    <bridge id="bat_bridge" type="adc">
      <analog_source net="bat_sense"/>
      <digital_target component="U_MCU" peripheral="ADC1" channel="ADC1_CH0"/>
    </bridge>
  </bridges>

  <tests>
    <test id="gateway_nominal">
      <description>Verify power rail stability and ADC levels during radio TX.</description>
      <setup>
        <set_voltage net="v_ext" value="12V"/>
        <set_voltage net="v_bat" value="4.0V"/>
      </setup>
      <run duration="1s"/>
      <assert_voltage net="v_3v3" min="3.2V" max="3.4V"/>
      <assert_voltage net="v_1v8" min="1.7V" max="1.9V"/>
      <assert_voltage net="bat_sense" min="1.2V" max="1.4V"/>
    </test>
  </tests>

  <simulation_profiles>
    <profile id="mixed_signal" default="true">
      <backend type="ngspice"/>
      <backend type="renode"/>
      <run test="gateway_nominal"/>
    </profile>
  </simulation_profiles>
</system>
