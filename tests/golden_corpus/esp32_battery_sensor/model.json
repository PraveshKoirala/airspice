      "data": {
        "analog_source": {
          "net": "battery_sense"
        },
        "conversion": {
          "bits": "12",
          "reference_voltage": "3.3V"
        },
        "digital_target": {
          "channel": "ADC1_CH4",
          "component": "U_MCU",
          "peripheral": "ADC1"
        },
        "id": "battery_adc_bridge",
        "sampling": {
          "sample_rate": "1kHz",
          "sample_time": "10us"
        },
        "type": "adc"
      },
