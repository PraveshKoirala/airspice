  "firmware_source": {
    "entry": "main",
    "language": "micropython",
    "mcu": "U_MCU",
    "pins": [
      "GPIO4",
      "GPIO5"
    ],
    "source": "\nfrom machine import ADC, Pin\nimport time\n\nadc = ADC(Pin(4))\npump = Pin(5, Pin.OUT)\n\ndef main():\n    while True:\n        mv = adc.read_u16() * 3300 // 65535\n        if mv < 1200:\n            pump.value(1)\n        else:\n            pump.value(0)\n        time.sleep_ms(100)\n"
  },
