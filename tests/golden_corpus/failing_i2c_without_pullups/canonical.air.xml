<?xml version="1.0" ?>
<system ir_version="0.1" name="i2c_without_pullups">
  <metadata>
    <title>I2C Without Pullups</title>
  </metadata>
  <nets>
    <net id="3v3" nominal_voltage="3.3V" role="power"/>
    <net id="gnd" role="ground"/>
    <net id="scl" role="digital_signal"/>
    <net id="sda" role="digital_signal"/>
  </nets>
  <components>
    <component id="U_MCU" part="ESP32-C3" type="mcu">
      <pin name="3V3" net="3v3"/>
      <pin name="GND" net="gnd"/>
      <pin function="I2C_SDA" name="GPIO8" net="sda"/>
      <pin function="I2C_SCL" name="GPIO9" net="scl"/>
    </component>
  </components>
  <interfaces>
    <interface id="i2c0" type="i2c">
      <controller component="U_MCU" peripheral="I2C0"/>
      <sda net="sda"/>
      <scl net="scl"/>
    </interface>
  </interfaces>
  <tests>
    <test id="noop">
      <run duration="1ms"/>
    </test>
  </tests>
  <simulation_profiles>
    <profile id="analog_only">
      <backend type="ngspice"/>
      <run test="noop"/>
    </profile>
  </simulation_profiles>
</system>
