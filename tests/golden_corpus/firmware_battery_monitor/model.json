  "firmware_source": {
    "entry": "main",
    "language": "micropython",
    "mcu": "U_MCU",
    "pins": [
      "GPIO4"
    ],
    "source": "\nfrom machine import ADC, Pin\nimport time\n\n# guard: the CDATA-end marker ']]>' must survive canonicalization verbatim\nadc = ADC(Pin(4))\n\ndef main():\n    while True:\n        raw = adc.read_u16()\n        mv = raw * 3300 // 65535\n        print('battery_mv', mv)\n        time.sleep_ms(1000)\n"
  },
