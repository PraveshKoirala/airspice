  "firmware_source": {
    "entry": "main",
    "language": "micropython",
    "mcu": "U_MCU",
    "pins": [
      "GPIO5"
    ],
    "source": "\nfrom machine import Pin, PWM\nimport time\n\nled = PWM(Pin(5))\nled.freq(1000)\n\ndef main():\n    duty = 0\n    step = 512\n    while True:\n        led.duty_u16(duty)\n        duty += step\n        if duty >= 65535 or duty <= 0:\n            step = -step\n        time.sleep_ms(20)\n"
  },
