I_U_REG_iq v_bat 0 DC 100uA
E_U_REG v_logic 0 VALUE = { min(3.3V, V(v_bat) - 0.2V) }
V_V_BAT v_bat 0 DC 3.7V
V_V_SOLAR v_solar_raw 0 DC 5.5V
.tran 1u 200ms
