<system name="solar_sensor_node" ir_version="0.1">
  <metadata>
    <title>Solar Powered Sensor Node</title>
    <description>Solar panel charging a battery with MCU-controlled load switching and dual-rail sensing.</description>
  </metadata>

  <nets>
    <net id="gnd" role="ground"/>
    <net id="v_solar_raw" role="power"/>
    <net id="v_solar" role="power" nominal_voltage="5.5V"/>
    <net id="v_bat" role="power" nominal_voltage="3.7V"/>
    <net id="v_logic" role="power" nominal_voltage="3.3V"/>
    <net id="solar_sense" role="analog_signal"/>
    <net id="bat_sense" role="analog_signal"/>
    <net id="load_ctrl" role="digital_signal"/>
    <net id="load_low" role="analog_signal"/>
  </nets>

  <components>
    <!-- Solar Input with protection diode -->
    <component id="V_SOLAR" type="voltage_source">
      <value>5.5V</value>
      <pin name="p" net="v_solar_raw"/>
      <pin name="n" net="gnd"/>
    </component>
    
    <component id="R_SOLAR_INTERNAL" type="resistor">
      <value>10</value>
      <pin name="1" net="v_solar_raw"/>
      <pin name="2" net="v_solar"/>
    </component>
    
    <component id="D_SCHOTTKY" type="diode" spice_model="1N5819">
      <pin name="a" net="v_solar"/>
      <pin name="c" net="v_bat"/>
    </component>

    <!-- Main Battery -->
    <component id="V_BAT" type="voltage_source">
      <value>3.7V</value>
      <pin name="p" net="v_bat"/>
      <pin name="n" net="gnd"/>
    </component>

    <!-- System Regulator -->
    <component id="U_REG" type="ldo">
      <pin name="in" net="v_bat"/>
      <pin name="out" net="v_logic"/>
      <pin name="gnd" net="gnd"/>
      <property name="vout" value="3.3V"/>
      <property name="iout_max" value="500mA"/>
      <property name="v_dropout" value="0.2V"/>
      <property name="iq" value="100uA"/>
    </component>

    <!-- Controller -->
    <component id="U_MCU" type="mcu" part="ESP32-C3">
      <pin name="3V3" net="v_logic"/>
      <pin name="GND" net="gnd"/>
      <pin name="GPIO0" net="solar_sense" function="ADC1_CH0"/>
      <pin name="GPIO1" net="bat_sense" function="ADC1_CH1"/>
      <pin name="GPIO2" net="load_ctrl" function="GPIO_OUT"/>
    </component>

    <!-- Load Switching -->
    <component id="Q_LOAD_SW" type="mosfet" spice_model="2N7002">
      <pin name="G" net="load_ctrl"/>
      <pin name="D" net="load_low"/>
      <pin name="S" net="gnd"/>
    </component>

    <component id="L_SYSTEM" type="generic_load">
      <value>150mA</value>
      <pin name="p" net="v_bat"/>
      <pin name="n" net="load_low"/>
    </component>

    <!-- Sensing Dividers -->
    <component id="R_SOLAR_TOP" type="resistor">
      <value>1M</value>
      <pin name="1" net="v_solar"/>
      <pin name="2" net="solar_sense"/>
    </component>
    <component id="R_SOLAR_BOT" type="resistor">
      <value>470k</value>
      <pin name="1" net="solar_sense"/>
      <pin name="2" net="gnd"/>
    </component>

    <component id="R_BAT_TOP" type="resistor">
      <value>1M</value>
      <pin name="1" net="v_bat"/>
      <pin name="2" net="bat_sense"/>
    </component>
    <component id="R_BAT_BOT" type="resistor">
      <value>1M</value>
      <pin name="1" net="bat_sense"/>
      <pin name="2" net="gnd"/>
    </component>
  </components>

  <firmware>
    <project id="fw_main" target="U_MCU" framework="platformio" language="cpp">
      <board>esp32-c3-devkitm-1</board>
    </project>
    
    <binding id="solar_adc">
      <signal name="solar_v"/>
      <component ref="U_MCU"/>
      <peripheral>ADC1</peripheral>
      <channel>ADC1_CH0</channel>
      <net>solar_sense</net>
    </binding>

    <binding id="bat_adc">
      <signal name="battery_v"/>
      <component ref="U_MCU"/>
      <peripheral>ADC1</peripheral>
      <channel>ADC1_CH1</channel>
      <net>bat_sense</net>
    </binding>

    <task id="power_management" target="fw_main">
      <period>100ms</period>
      <read_adc binding="solar_adc" into="s_val"/>
      <read_adc binding="bat_adc" into="b_val"/>
      <!-- If battery is high enough, enable load -->
      <write_gpio pin="GPIO2" value="high"/>
    </task>
  </firmware>

  <bridges>
    <bridge id="solar_bridge" type="adc">
      <analog_source net="solar_sense"/>
      <digital_target component="U_MCU" peripheral="ADC1" channel="ADC1_CH0"/>
      <conversion bits="12" reference_voltage="3.3V"/>
    </bridge>
    <bridge id="bat_bridge" type="adc">
      <analog_source net="bat_sense"/>
      <digital_target component="U_MCU" peripheral="ADC1" channel="ADC1_CH1"/>
      <conversion bits="12" reference_voltage="3.3V"/>
    </bridge>
  </bridges>

  <tests>
    <test id="charging_scenario">
      <description>Verify voltage levels during active charging.</description>
      <setup>
        <set_voltage net="v_solar" value="5.5V"/>
        <set_voltage net="v_bat" value="3.7V"/>
      </setup>
      <run duration="200ms"/>
      <assert_voltage net="v_logic" min="3.2V" max="3.4V"/>
      <assert_voltage net="solar_sense" min="1.7V" max="1.8V"/>
      <assert_voltage net="bat_sense" min="1.8V" max="1.9V"/>
    </test>
  </tests>

  <simulation_profiles>
    <profile id="mixed_signal" default="true">
      <backend type="ngspice"/>
      <backend type="renode"/>
      <run test="charging_scenario"/>
    </profile>
  </simulation_profiles>
</system>
