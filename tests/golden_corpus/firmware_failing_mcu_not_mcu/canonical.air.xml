<?xml version="1.0" ?>
<system ir_version="0.1" name="firmware_failing_mcu_not_mcu">
  <metadata>
    <title>Firmware source whose mcu ref is not MCU-typed</title>
    <description>Otherwise-valid design; the firmware source names a resistor as its mcu, so it must fail with FIRMWARE_MCU_NOT_MCU (issue #36).</description>
    <author>AI</author>
    <created_at>2026-07-24T00:00:00Z</created_at>
  </metadata>
  <nets>
    <net id="3v3" nominal_voltage="3.3V" role="power"/>
    <net id="gnd" role="ground"/>
    <net id="soil_sense" role="analog_signal"/>
  </nets>
  <components>
    <component id="R_SOIL_BOTTOM" type="resistor">
      <value>10k</value>
      <pin name="1" net="soil_sense"/>
      <pin name="2" net="gnd"/>
    </component>
    <component id="R_SOIL_TOP" type="resistor">
      <value>10k</value>
      <pin name="1" net="3v3"/>
      <pin name="2" net="soil_sense"/>
    </component>
    <component id="U_MCU" part="ESP32-C3" type="mcu">
      <pin name="3V3" net="3v3"/>
      <pin name="GND" net="gnd"/>
      <pin function="ADC1_CH4" name="GPIO4" net="soil_sense"/>
    </component>
  </components>
  <firmware entry="main" language="micropython" mcu="R_SOIL_TOP" pins="GPIO4">
    <source><![CDATA[
from machine import ADC, Pin
adc = ADC(Pin(4))

def main():
    print(adc.read_u16())
]]></source>
  </firmware>
  <tests>
    <test id="soil_divider_nominal">
      <setup>
        <set_voltage net="3v3" value="3.3V"/>
      </setup>
      <run duration="10ms"/>
      <assert_voltage max="1.7V" min="1.6V" net="soil_sense"/>
    </test>
  </tests>
  <simulation_profiles>
    <profile default="true" id="firmware_profile">
      <backend type="renode"/>
      <run test="soil_divider_nominal"/>
    </profile>
  </simulation_profiles>
</system>
