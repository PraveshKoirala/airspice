<?xml version="1.0" ?>
<system ir_version="0.1" name="stm32_demo">
  <metadata>
    <title>STM32 Demo</title>
  </metadata>
  <nets>
    <net id="gnd" role="ground"/>
    <net id="v_3v3" nominal_voltage="3.3V" role="power"/>
  </nets>
  <components>
    <component id="U_MCU" part="STM32F103" type="mcu">
      <pin name="VDD" net="v_3v3"/>
      <pin name="VSS" net="gnd"/>
    </component>
    <component id="V_SOURCE" type="voltage_source">
      <value>3.3V</value>
      <pin name="p" net="v_3v3"/>
      <pin name="n" net="gnd"/>
    </component>
  </components>
  <firmware>
    <project framework="platformio" id="fw" language="cpp" target="U_MCU">
      <board>bluepill_f103c8</board>
    </project>
  </firmware>
  <tests>
    <test id="t1">
      <run duration="10ms"/>
    </test>
  </tests>
  <simulation_profiles>
    <profile default="true" id="p1">
      <backend type="renode"/>
      <run test="t1"/>
    </profile>
  </simulation_profiles>
</system>
