<system name="gt113_led_esp32c3_binding_wrong" ir_version="0.1">
  <metadata>
    <title>ESP32-C3 LED (binding-form firmware, WRONG net)</title>
    <description>Issue #113 wrong-mutation fixture. The circuit still drives the LED from GPIO2/led_drive, but the firmware binding ind_led resolves — by declared net AND by channel-to-pin-function — to a DIFFERENT real GPIO pin (GPIO4/aux_drive), not the led_drive net the intent requires. A correct (real-resolution) scorer must REJECT this: the widening accepts the binding= SHAPE but the resolved target must still match the required net. A naive accept-any-binding widening would wrongly pass it.</description>
    <author>issue-113-tester</author>
  </metadata>
  <nets>
    <net id="gnd" role="ground"/>
    <net id="v3v3" role="power" nominal_voltage="3.3V"/>
    <net id="led_drive" role="digital_signal"/>
    <net id="led_anode" role="analog_signal"/>
    <net id="aux_drive" role="digital_signal"/>
  </nets>
  <components>
    <component id="V_3V3" type="voltage_source">
      <value>3.3V</value>
      <pin name="p" net="v3v3"/>
      <pin name="n" net="gnd"/>
    </component>
    <component id="R_LIMIT" type="resistor">
      <value>330</value>
      <pin name="1" net="led_drive"/>
      <pin name="2" net="led_anode"/>
    </component>
    <component id="D_LED" type="diode" part="1N4148">
      <pin name="a" net="led_anode"/>
      <pin name="c" net="gnd"/>
    </component>
    <component id="R_AUX" type="resistor">
      <value>10k</value>
      <pin name="1" net="aux_drive"/>
      <pin name="2" net="gnd"/>
    </component>
    <component id="U_MCU" type="mcu" part="ESP32-C3">
      <pin name="3V3" net="v3v3"/>
      <pin name="GND" net="gnd"/>
      <pin name="GPIO2" net="led_drive" function="GPIO_OUT"/>
      <pin name="GPIO4" net="aux_drive" function="GPIO"/>
    </component>
  </components>
  <firmware>
    <project id="fw_main" target="U_MCU" framework="platformio" language="cpp">
      <board>esp32-c3-devkitm-1</board>
      <source_tree path="firmware/"/>
    </project>
    <binding id="ind_led">
      <signal name="ind_led"/>
      <component ref="U_MCU"/>
      <channel>GPIO</channel>
      <net>aux_drive</net>
    </binding>
    <task id="drive" target="fw_main">
      <write_gpio binding="ind_led" value="high"/>
    </task>
  </firmware>
  <analog>
    <subsystem id="s">
      <uses component="R_LIMIT"/>
      <uses component="D_LED"/>
      <uses component="R_AUX"/>
      <probe id="probe_led_anode" net="led_anode" quantity="voltage"/>
    </subsystem>
  </analog>
  <tests>
    <test id="t">
      <run duration="1ms"/>
      <assert_voltage net="led_anode" min="0.4V" max="0.9V"/>
    </test>
  </tests>
  <simulation_profiles>
    <profile id="analog_only" default="true">
      <backend type="ngspice"/>
      <include subsystem="s"/>
      <run test="t"/>
    </profile>
  </simulation_profiles>
</system>
