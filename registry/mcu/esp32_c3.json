    "GPIO2": ["GPIO", "ADC1_CH2", "GPIO_OUT"],
    "GPIO3": ["GPIO", "ADC1_CH3", "GPIO_OUT"],
    "GPIO4": ["GPIO", "ADC1_CH4", "GPIO_OUT"],
    "GPIO5": ["GPIO", "ADC1_CH5", "GPIO_OUT"],
    "GPIO8": ["GPIO", "I2C_SDA", "GPIO_OUT"],
    "GPIO9": ["GPIO", "I2C_SCL", "GPIO_OUT"],
    "TX": ["UART_TX"],
    "RX": ["UART_RX"]
  },
  "peripherals": {
