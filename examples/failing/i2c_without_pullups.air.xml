<system name="i2c_without_pullups" ir_version="0.1">
  <metadata><title>I2C Without Pullups</title></metadata>
  <nets><net id="gnd" role="ground"/><net id="3v3" role="power" nominal_voltage="3.3V"/><net id="sda" role="digital_signal"/><net id="scl" role="digital_signal"/></nets>
  <components><component id="U_MCU" type="mcu" part="ESP32-C3"><pin name="3V3" net="3v3"/><pin name="GND" net="gnd"/><pin name="GPIO8" net="sda" function="I2C_SDA"/><pin name="GPIO9" net="scl" function="I2C_SCL"/></component></components>
  <interfaces><interface id="i2c0" type="i2c"><controller component="U_MCU" peripheral="I2C0"/><sda net="sda"/><scl net="scl"/></interface></interfaces>
  <tests><test id="noop"><run duration="1ms"/></test></tests>
  <simulation_profiles><profile id="analog_only"><backend type="ngspice"/><run test="noop"/></profile></simulation_profiles>
</system>

