{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Workspaces refactor (issue #85): the UI's TS resolution for the sibling
       packages (air-ts, agent, sim-wasm) now goes through the ordinary npm
       workspace symlink at node_modules/<name>, and their transitive deps
       (fast-xml-parser via air-ts, eecircuit-engine via sim-wasm) are hoisted
       by npm. No `paths` overrides are needed -- the drift landmine from #85
       (a consumer's fast-xml-parser copy not matching air-ts's declared
       range) is gone because there's exactly one copy per name. */

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
