<system name="d8_duplicate_gpio" ir_version="0.1">
  <metadata>
    <title>list.index content-equality quirk: two identical write_gpio ops, different delays</title>
  </metadata>
  <nets>
    <net id="v33" role="power" nominal_voltage="3.3V"/>
    <net id="sig" role="digital_signal"/>
    <net id="gnd" role="ground"/>
  </nets>
  <components>
    <component id="V_33" type="voltage_source">
      <pin name="p" net="v33"/>
      <pin name="n" net="gnd"/>
      <value>3.3V</value>
    </component>
    <component id="U_MCU" type="mcu" part="ESP32-C3">
      <pin name="3V3" net="v33"/>
      <pin name="GND" net="gnd"/>
      <pin name="GPIO0" net="sig" function="GPIO_OUT"/>
    </component>
  </components>
  <firmware>
    <project id="fw" target="U_MCU" framework="platformio" language="cpp">
      <board>esp32-c3-devkitm-1</board>
    </project>
    <task id="tq" target="fw">
      <period>10ms</period>
      <write_gpio pin="GPIO0" value="high"/>
      <delay duration="1ms"/>
      <write_gpio pin="GPIO0" value="high"/>
      <delay duration="3ms"/>
    </task>
  </firmware>
  <tests>
    <test id="quirk_probe">
      <run duration="20ms"/>
      <assert_voltage net="sig" min="0V" max="3.4V"/>
    </test>
  </tests>
  <simulation_profiles>
    <profile id="mixed" default="true">
      <backend type="ngspice"/>
      <backend type="renode"/>
      <run test="quirk_probe"/>
    </profile>
  </simulation_profiles>
</system>
