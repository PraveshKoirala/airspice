{
  "name": "agent",
  "version": "0.1.0",
  "private": true,
  "description": "Browser BYOK agent layer: provider-agnostic LLM client (Anthropic/OpenAI/Gemini/Mock), streaming + native tool use, direct-from-browser calls, local-only key vault (issue #17). No server, no relay.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b && tsc -p tsconfig.test.json && tsc -p bench/tsconfig.check.json",
    "bench": "tsx --tsconfig ./bench/tsconfig.bench.json ./bench/run.ts",
    "build-bench": "tsx --tsconfig ./bench/tsconfig.bench.json ./bench/build/run.ts"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "fast-xml-parser": "^5.9.3",
    "tsx": "^4.19.2",
    "typescript": "~5.6.3",
    "vitest": "^2.1.8"
  }
}
