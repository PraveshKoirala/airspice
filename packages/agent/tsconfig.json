{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,

    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  /* Workspaces refactor (issue #85): `air-ts` is a real workspace dependency,
     so `tsc -b` on this package resolves it via node_modules/air-ts -> the
     built dist/index.d.ts (air-ts's package.json `exports.types`). The
     project reference below tells TypeScript to build packages/air-ts first
     when this project is built, so the .d.ts is present. The old
     src/air-ts.d.ts ambient stub was deleted -- real types replace it. */
  "references": [
    { "path": "../air-ts" }
  ],
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
