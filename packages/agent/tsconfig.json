{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,

    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  /* The tool runtime (issue #18) consumes the air-ts engine. At BUILD time
     `air-ts` is an AMBIENT module (src/air-ts.d.ts) declaring only the small
     value surface the ported prompts use, so `tsc -b` never pulls air-ts's
     SOURCE into this emitting composite project (its source is outside rootDir,
     and packages/air-ts/node_modules is not installed in the `agent` CI job). At
     RUNTIME the real air-ts source resolves via the Vite alias (UI) and the
     Vitest alias (this package's tests) -- the same source-aliased peer
     consumption packages/ui uses. */
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
