<system name="gt106_led_atmega_npn_driver" ir_version="0.1">
  <metadata>
    <title>LED via NPN</title>
    <description>Golden build for issue #106 build-spec corpus. Known-good, ERC-clean, simulates to the spec sim_assertion on ngspice.</description>
    <author>issue-106</author>
  </metadata>
  <nets>
    <net id="gnd" role="ground"/>
    <net id="v5" role="power" nominal_voltage="5V"/>
    <net id="base_drive" role="digital_signal"/>
    <net id="base" role="analog_signal"/>
    <net id="led_anode" role="analog_signal"/>
    <net id="led_cathode" role="analog_signal"/>
  </nets>
  <components>
    <component id="V_5" type="voltage_source">
      <value>5V</value>
      <pin name="p" net="v5"/>
      <pin name="n" net="gnd"/>
    </component>
    <component id="R_BASE" type="resistor">
      <value>1k</value>
      <pin name="1" net="base_drive"/>
      <pin name="2" net="base"/>
    </component>
    <component id="R_LIMIT" type="resistor">
      <value>330</value>
      <pin name="1" net="v5"/>
      <pin name="2" net="led_anode"/>
    </component>
    <component id="D_LED" type="diode" part="1N4148">
      <pin name="a" net="led_anode"/>
      <pin name="c" net="led_cathode"/>
    </component>
    <component id="Q1" type="bjt" part="2N2222">
      <pin name="C" net="led_cathode"/>
      <pin name="B" net="base"/>
      <pin name="E" net="gnd"/>
    </component>
    <component id="U_MCU" type="mcu" part="ATmega328P">
      <pin name="VCC" net="v5"/>
      <pin name="GND" net="gnd"/>
      <pin name="D2" net="base_drive" function="GPIO_OUT"/>
    </component>
  </components>
  <firmware>
    <project id="fw_main" target="U_MCU" framework="platformio" language="cpp">
      <board>uno</board>
      <source_tree path="firmware/"/>
    </project>
    <task id="drive" target="fw_main">
      <write_gpio pin="D2" value="high"/>
    </task>
  </firmware>
  <analog>
    <subsystem id="s">
      <uses component="V_5"/>
      <uses component="R_BASE"/>
      <uses component="R_LIMIT"/>
      <uses component="D_LED"/>
      <uses component="Q1"/>
      <probe id="probe_led_cathode" net="led_cathode" quantity="voltage"/>
    </subsystem>
  </analog>
  <tests>
    <test id="t">
      <setup><set_voltage net="v5" value="5V"/></setup>
      <run duration="1ms"/>
      <assert_voltage net="led_cathode" min="0.0V" max="1.0V"/>
    </test>
  </tests>
  <simulation_profiles>
    <profile id="analog_only" default="true">
      <backend type="ngspice"/>
      <include subsystem="s"/>
      <run test="t"/>
    </profile>
  </simulation_profiles>
</system>
