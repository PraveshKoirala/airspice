<system name="gt106_sensor_atmega_i2c_stub" ir_version="0.1">
  <metadata>
    <title>I2C stub</title>
    <description>Golden build for issue #106 build-spec corpus. Known-good, ERC-clean, simulates to the spec sim_assertion on ngspice.</description>
    <author>issue-106</author>
  </metadata>
  <nets>
    <net id="gnd" role="ground"/>
    <net id="v5" role="power" nominal_voltage="5V"/>
    <net id="i2c_sda" role="digital_signal"/>
    <net id="i2c_scl" role="digital_signal"/>
  </nets>
  <components>
    <component id="V_5" type="voltage_source">
      <value>5V</value>
      <pin name="p" net="v5"/>
      <pin name="n" net="gnd"/>
    </component>
    <component id="R_PU_SDA" type="resistor">
      <value>4.7k</value>
      <pin name="1" net="v5"/>
      <pin name="2" net="i2c_sda"/>
    </component>
    <component id="R_PU_SCL" type="resistor">
      <value>4.7k</value>
      <pin name="1" net="v5"/>
      <pin name="2" net="i2c_scl"/>
    </component>
    <component id="U_SENSOR" type="generic_load" part="I2C_SENSOR_STUB">
      <pin name="p" net="v5"/>
      <pin name="n" net="gnd"/>
      <property name="current" value="1mA"/>
    </component>
    <component id="U_MCU" type="mcu" part="ATmega328P">
      <pin name="VCC" net="v5"/>
      <pin name="GND" net="gnd"/>
      <pin name="A4" net="i2c_sda" function="I2C_SDA"/>
      <pin name="A5" net="i2c_scl" function="I2C_SCL"/>
    </component>
  </components>
  <interfaces>
    <interface id="i2c0" type="i2c">
      <controller component="U_MCU" peripheral="I2C0"/>
      <sda net="i2c_sda"/>
      <scl net="i2c_scl"/>
      <pullup net="i2c_sda" value="4.7k" to="v5"/>
      <pullup net="i2c_scl" value="4.7k" to="v5"/>
    </interface>
  </interfaces>
  <analog>
    <subsystem id="s">
      <uses component="R_PU_SDA"/>
      <uses component="R_PU_SCL"/>
      <uses component="U_SENSOR"/>
      <probe id="probe_i2c_sda" net="i2c_sda" quantity="voltage"/>
      <probe id="probe_i2c_scl" net="i2c_scl" quantity="voltage"/>
    </subsystem>
  </analog>
  <tests>
    <test id="t">
      <setup><set_voltage net="v5" value="5V"/></setup>
      <run duration="1ms"/>
      <assert_voltage net="i2c_sda" min="4.9V" max="5.05V"/>
      <assert_voltage net="i2c_scl" min="4.9V" max="5.05V"/>
    </test>
  </tests>
  <simulation_profiles>
    <profile id="analog_only" default="true">
      <backend type="ngspice"/>
      <include subsystem="s"/>
      <run test="t"/>
    </profile>
  </simulation_profiles>
</system>
