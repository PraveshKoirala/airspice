<system name="gt106_comp_esp32c3_batmon_ldo_led" ir_version="0.1">
  <metadata>
    <title>Battery monitor composite</title>
    <description>Golden build for issue #106 build-spec corpus. Known-good, ERC-clean, simulates to the spec sim_assertion on ngspice.</description>
    <author>issue-106</author>
  </metadata>
  <nets>
    <net id="gnd" role="ground"/>
    <net id="vbat" role="power" nominal_voltage="4.2V"/>
    <net id="v3v3" role="power" nominal_voltage="3.3V"/>
    <net id="batt_sense" role="analog_signal"/>
    <net id="led_drive" role="digital_signal"/>
    <net id="led_anode" role="analog_signal"/>
  </nets>
  <components>
    <component id="V_BAT" type="voltage_source">
      <value>4.2V</value>
      <pin name="p" net="vbat"/>
      <pin name="n" net="gnd"/>
    </component>
    <component id="U_REG" type="ldo">
      <pin name="in" net="vbat"/>
      <pin name="out" net="v3v3"/>
      <pin name="gnd" net="gnd"/>
      <property name="vout" value="3.3V"/>
      <property name="iout_max" value="800mA"/>
      <property name="v_dropout" value="0.2V"/>
      <property name="iq" value="50uA"/>
    </component>
    <component id="R_TOP" type="resistor">
      <value>100k</value>
      <pin name="1" net="vbat"/>
      <pin name="2" net="batt_sense"/>
    </component>
    <component id="R_BOT" type="resistor">
      <value>100k</value>
      <pin name="1" net="batt_sense"/>
      <pin name="2" net="gnd"/>
    </component>
    <component id="R_LED" type="resistor">
      <value>330</value>
      <pin name="1" net="led_drive"/>
      <pin name="2" net="led_anode"/>
    </component>
    <component id="D_LED" type="diode" part="1N4148">
      <pin name="a" net="led_anode"/>
      <pin name="c" net="gnd"/>
    </component>
    <component id="U_MCU" type="mcu" part="ESP32-C3">
      <pin name="3V3" net="v3v3"/>
      <pin name="GND" net="gnd"/>
      <pin name="GPIO0" net="batt_sense" function="ADC1_CH0"/>
      <pin name="GPIO2" net="led_drive" function="GPIO_OUT"/>
    </component>
  </components>
  <firmware>
    <project id="fw_main" target="U_MCU" framework="platformio" language="cpp">
      <board>esp32-c3-devkitm-1</board>
      <source_tree path="firmware/"/>
    </project>
    <binding id="adc_binding">
      <signal name="batt"/>
      <component ref="U_MCU"/>
      <peripheral>ADC1</peripheral>
      <channel>ADC1_CH0</channel>
      <net>batt_sense</net>
    </binding>
    <task id="monitor" target="fw_main">
      <read_adc binding="adc_binding" into="v_raw"/>
      <log value="v_raw"/>
      <write_gpio pin="GPIO2" value="high"/>
    </task>
  </firmware>
  <analog>
    <subsystem id="s">
      <uses component="V_BAT"/>
      <uses component="U_REG"/>
      <uses component="R_TOP"/>
      <uses component="R_BOT"/>
      <uses component="R_LED"/>
      <uses component="D_LED"/>
      <probe id="probe_batt_sense" net="batt_sense" quantity="voltage"/>
      <probe id="probe_v3v3" net="v3v3" quantity="voltage"/>
    </subsystem>
  </analog>
  <tests>
    <test id="t">
      <setup><set_voltage net="vbat" value="4.2V"/></setup>
      <run duration="1ms"/>
      <assert_voltage net="batt_sense" min="2.0V" max="2.2V"/>
      <assert_voltage net="v3v3" min="3.2V" max="3.4V"/>
    </test>
  </tests>
  <simulation_profiles>
    <profile id="analog_only" default="true">
      <backend type="ngspice"/>
      <include subsystem="s"/>
      <run test="t"/>
    </profile>
  </simulation_profiles>
</system>
