<system name="gt106_adc_stm32_potentiometer" ir_version="0.1">
  <metadata>
    <title>STM32 pot</title>
    <description>Golden build for issue #106 build-spec corpus. Known-good, ERC-clean, simulates to the spec sim_assertion on ngspice.</description>
    <author>issue-106</author>
  </metadata>
  <nets>
    <net id="gnd" role="ground"/>
    <net id="v3v3" role="power" nominal_voltage="3.3V"/>
    <net id="wiper" role="analog_signal"/>
  </nets>
  <components>
    <component id="V_3V3" type="voltage_source">
      <value>3.3V</value>
      <pin name="p" net="v3v3"/>
      <pin name="n" net="gnd"/>
    </component>
    <component id="R_TOPHALF" type="resistor">
      <value>5k</value>
      <pin name="1" net="v3v3"/>
      <pin name="2" net="wiper"/>
    </component>
    <component id="R_BOTHALF" type="resistor">
      <value>5k</value>
      <pin name="1" net="wiper"/>
      <pin name="2" net="gnd"/>
    </component>
    <component id="U_MCU" type="mcu" part="STM32F103">
      <pin name="VDD" net="v3v3"/>
      <pin name="VSS" net="gnd"/>
      <pin name="PA0" net="wiper" function="ADC1_CH0"/>
    </component>
  </components>
  <firmware>
    <project id="fw_main" target="U_MCU" framework="platformio" language="cpp">
      <board>bluepill_f103c8</board>
      <source_tree path="firmware/"/>
    </project>
    <binding id="adc_binding">
      <signal name="sense"/>
      <component ref="U_MCU"/>
      <peripheral>ADC1</peripheral>
      <channel>ADC1_CH0</channel>
      <net>wiper</net>
    </binding>
    <task id="read_sense" target="fw_main">
      <period>1s</period>
      <read_adc binding="adc_binding" into="v_raw"/>
    </task>
  </firmware>
  <analog>
    <subsystem id="s">
      <uses component="V_3V3"/>
      <uses component="R_TOPHALF"/>
      <uses component="R_BOTHALF"/>
      <probe id="probe_wiper" net="wiper" quantity="voltage"/>
    </subsystem>
  </analog>
  <tests>
    <test id="t">
      <setup><set_voltage net="v3v3" value="3.3V"/></setup>
      <run duration="1ms"/>
      <assert_voltage net="wiper" min="1.6V" max="1.7V"/>
    </test>
  </tests>
  <simulation_profiles>
    <profile id="analog_only" default="true">
      <backend type="ngspice"/>
      <include subsystem="s"/>
      <run test="t"/>
    </profile>
  </simulation_profiles>
</system>
