<system name="gt106_btn_atmega_multi" ir_version="0.1">
  <metadata>
    <title>Two buttons</title>
    <description>Golden build for issue #106 build-spec corpus. Known-good, ERC-clean, simulates to the spec sim_assertion on ngspice.</description>
    <author>issue-106</author>
  </metadata>
  <nets>
    <net id="gnd" role="ground"/>
    <net id="v5" role="power" nominal_voltage="5V"/>
    <net id="up_btn" role="digital_signal"/>
    <net id="down_btn" role="digital_signal"/>
  </nets>
  <components>
    <component id="V_5" type="voltage_source">
      <value>5V</value>
      <pin name="p" net="v5"/>
      <pin name="n" net="gnd"/>
    </component>
    <component id="R_PU_UP" type="resistor">
      <value>10k</value>
      <pin name="1" net="v5"/>
      <pin name="2" net="up_btn"/>
    </component>
    <component id="R_LK_UP" type="resistor">
      <value>10Meg</value>
      <pin name="1" net="up_btn"/>
      <pin name="2" net="gnd"/>
    </component>
    <component id="R_PU_DN" type="resistor">
      <value>10k</value>
      <pin name="1" net="v5"/>
      <pin name="2" net="down_btn"/>
    </component>
    <component id="R_LK_DN" type="resistor">
      <value>10Meg</value>
      <pin name="1" net="down_btn"/>
      <pin name="2" net="gnd"/>
    </component>
    <component id="U_MCU" type="mcu" part="ATmega328P">
      <pin name="VCC" net="v5"/>
      <pin name="GND" net="gnd"/>
      <pin name="D7" net="up_btn" function="GPIO"/>
      <pin name="D8" net="down_btn" function="GPIO"/>
    </component>
  </components>
  <firmware>
    <project id="fw_main" target="U_MCU" framework="platformio" language="cpp">
      <board>uno</board>
      <source_tree path="firmware/"/>
    </project>
    <binding id="adc_binding">
      <signal name="sense"/>
      <component ref="U_MCU"/>
      <peripheral>ADC1</peripheral>
      <channel>ADC1_CH0</channel>
      <net>up_btn</net>
    </binding>
    <task id="read_sense" target="fw_main">
      <period>1s</period>
      <read_adc binding="adc_binding" into="v_raw"/>
    </task>
  </firmware>
  <analog>
    <subsystem id="s">
      <uses component="R_PU_UP"/>
      <uses component="R_LK_UP"/>
      <uses component="R_PU_DN"/>
      <uses component="R_LK_DN"/>
      <probe id="probe_up_btn" net="up_btn" quantity="voltage"/>
      <probe id="probe_down_btn" net="down_btn" quantity="voltage"/>
    </subsystem>
  </analog>
  <tests>
    <test id="t">
      <setup><set_voltage net="v5" value="5V"/></setup>
      <run duration="1ms"/>
      <assert_voltage net="up_btn" min="4.9V" max="5.05V"/>
      <assert_voltage net="down_btn" min="4.9V" max="5.05V"/>
    </test>
  </tests>
  <simulation_profiles>
    <profile id="analog_only" default="true">
      <backend type="ngspice"/>
      <include subsystem="s"/>
      <run test="t"/>
    </profile>
  </simulation_profiles>
</system>
