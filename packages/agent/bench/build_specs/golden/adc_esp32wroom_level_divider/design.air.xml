<system name="gt106_adc_esp32wroom_level_divider" ir_version="0.1">
  <metadata>
    <title>WROOM 5V sensor</title>
    <description>Golden build for issue #106 build-spec corpus. Known-good, ERC-clean, simulates to the spec sim_assertion on ngspice.</description>
    <author>issue-106</author>
  </metadata>
  <nets>
    <net id="gnd" role="ground"/>
    <net id="sensor_5v" role="power" nominal_voltage="5V"/>
    <net id="v3v3" role="power" nominal_voltage="3.3V"/>
    <net id="sense" role="analog_signal"/>
  </nets>
  <components>
    <component id="V_SENSOR" type="voltage_source">
      <value>5V</value>
      <pin name="p" net="sensor_5v"/>
      <pin name="n" net="gnd"/>
    </component>
    <component id="V_3V3" type="voltage_source">
      <value>3.3V</value>
      <pin name="p" net="v3v3"/>
      <pin name="n" net="gnd"/>
    </component>
    <component id="R_TOP" type="resistor">
      <value>22k</value>
      <pin name="1" net="sensor_5v"/>
      <pin name="2" net="sense"/>
    </component>
    <component id="R_BOT" type="resistor">
      <value>15k</value>
      <pin name="1" net="sense"/>
      <pin name="2" net="gnd"/>
    </component>
    <component id="U_MCU" type="mcu" part="ESP32-WROOM-32">
      <pin name="3V3" net="v3v3"/>
      <pin name="GND" net="gnd"/>
      <pin name="GPIO32" net="sense" function="ADC1_CH4"/>
    </component>
  </components>
  <firmware>
    <project id="fw_main" target="U_MCU" framework="platformio" language="cpp">
      <board>esp32dev</board>
      <source_tree path="firmware/"/>
    </project>
    <binding id="adc_binding">
      <signal name="sense"/>
      <component ref="U_MCU"/>
      <peripheral>ADC1</peripheral>
      <channel>ADC1_CH4</channel>
      <net>sense</net>
    </binding>
    <task id="read_sense" target="fw_main">
      <period>1s</period>
      <read_adc binding="adc_binding" into="v_raw"/>
    </task>
  </firmware>
  <analog>
    <subsystem id="s">
      <uses component="V_SENSOR"/>
      <uses component="R_TOP"/>
      <uses component="R_BOT"/>
      <probe id="probe_sense" net="sense" quantity="voltage"/>
    </subsystem>
  </analog>
  <tests>
    <test id="t">
      <setup><set_voltage net="sensor_5v" value="5V"/></setup>
      <run duration="1ms"/>
      <assert_voltage net="sense" min="1.9V" max="2.1V"/>
    </test>
  </tests>
  <simulation_profiles>
    <profile id="analog_only" default="true">
      <backend type="ngspice"/>
      <include subsystem="s"/>
      <run test="t"/>
    </profile>
  </simulation_profiles>
</system>
