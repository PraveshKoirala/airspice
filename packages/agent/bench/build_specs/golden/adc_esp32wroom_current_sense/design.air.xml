<system name="gt106_adc_esp32wroom_current_sense" ir_version="0.1">
  <metadata>
    <title>Current sense</title>
    <description>Golden build for issue #106 build-spec corpus. Known-good, ERC-clean, simulates to the spec sim_assertion on ngspice.</description>
    <author>issue-106</author>
  </metadata>
  <nets>
    <net id="gnd" role="ground"/>
    <net id="v3v3" role="power" nominal_voltage="3.3V"/>
    <net id="shunt_hi" role="analog_signal"/>
  </nets>
  <components>
    <component id="V_3V3" type="voltage_source">
      <value>3.3V</value>
      <pin name="p" net="v3v3"/>
      <pin name="n" net="gnd"/>
    </component>
    <component id="I_LOAD" type="current_source">
      <value>200mA</value>
      <pin name="p" net="gnd"/>
      <pin name="n" net="shunt_hi"/>
    </component>
    <component id="R_SHUNT" type="resistor">
      <value>1</value>
      <pin name="1" net="shunt_hi"/>
      <pin name="2" net="gnd"/>
    </component>
    <component id="U_MCU" type="mcu" part="ESP32-WROOM-32">
      <pin name="3V3" net="v3v3"/>
      <pin name="GND" net="gnd"/>
      <pin name="GPIO32" net="shunt_hi" function="ADC1_CH4"/>
    </component>
  </components>
  <firmware>
    <project id="fw_main" target="U_MCU" framework="platformio" language="cpp">
      <board>esp32dev</board>
      <source_tree path="firmware/"/>
    </project>
    <binding id="adc_binding">
      <signal name="sense"/>
      <component ref="U_MCU"/>
      <peripheral>ADC1</peripheral>
      <channel>ADC1_CH4</channel>
      <net>shunt_hi</net>
    </binding>
    <task id="read_sense" target="fw_main">
      <period>1s</period>
      <read_adc binding="adc_binding" into="v_raw"/>
    </task>
  </firmware>
  <analog>
    <subsystem id="s">
      <uses component="V_3V3"/>
      <uses component="I_LOAD"/>
      <uses component="R_SHUNT"/>
      <probe id="probe_shunt_hi" net="shunt_hi" quantity="voltage"/>
    </subsystem>
  </analog>
  <tests>
    <test id="t">
      <run duration="1ms"/>
      <assert_voltage net="shunt_hi" min="0.18V" max="0.22V"/>
    </test>
  </tests>
  <simulation_profiles>
    <profile id="analog_only" default="true">
      <backend type="ngspice"/>
      <include subsystem="s"/>
      <run test="t"/>
    </profile>
  </simulation_profiles>
</system>
