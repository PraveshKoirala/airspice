<system name="gt106_pwm_esp32c3_rc_dac" ir_version="0.1">
  <metadata>
    <title>PWM RC DAC</title>
    <description>Golden build for issue #106 build-spec corpus. Known-good, ERC-clean, simulates to the spec sim_assertion on ngspice.</description>
    <author>issue-106</author>
  </metadata>
  <nets>
    <net id="gnd" role="ground"/>
    <net id="v3v3" role="power" nominal_voltage="3.3V"/>
    <net id="pwm" role="digital_signal"/>
    <net id="analog_out" role="analog_signal"/>
  </nets>
  <components>
    <component id="V_3V3" type="voltage_source">
      <value>3.3V</value>
      <pin name="p" net="v3v3"/>
      <pin name="n" net="gnd"/>
    </component>
    <component id="R_F" type="resistor">
      <value>10k</value>
      <pin name="1" net="pwm"/>
      <pin name="2" net="analog_out"/>
    </component>
    <component id="C_F" type="capacitor">
      <value>100nF</value>
      <pin name="1" net="analog_out"/>
      <pin name="2" net="gnd"/>
    </component>
    <component id="U_MCU" type="mcu" part="ESP32-C3">
      <pin name="3V3" net="v3v3"/>
      <pin name="GND" net="gnd"/>
      <pin name="GPIO2" net="pwm" function="GPIO_OUT"/>
    </component>
  </components>
  <firmware>
    <project id="fw_main" target="U_MCU" framework="platformio" language="cpp">
      <board>esp32-c3-devkitm-1</board>
      <source_tree path="firmware/"/>
    </project>
    <task id="pwm50" target="fw_main">
      <period>10us</period>
      <write_gpio pin="GPIO2" value="high"/>
      <delay duration="5us"/>
      <write_gpio pin="GPIO2" value="low"/>
    </task>
  </firmware>
  <analog>
    <subsystem id="s">
      <uses component="R_F"/>
      <uses component="C_F"/>
      <probe id="probe_analog_out" net="analog_out" quantity="voltage"/>
    </subsystem>
  </analog>
  <tests>
    <test id="t">
      <run duration="10ms"/>
      <assert_voltage net="analog_out" min="1.55V" max="1.75V"/>
    </test>
  </tests>
  <simulation_profiles>
    <profile id="analog_only" default="true">
      <backend type="ngspice"/>
      <include subsystem="s"/>
      <run test="t"/>
    </profile>
  </simulation_profiles>
</system>
