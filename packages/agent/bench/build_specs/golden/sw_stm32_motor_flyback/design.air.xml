<system name="gt106_sw_stm32_motor_flyback" ir_version="0.1">
  <metadata>
    <title>Motor + flyback</title>
    <description>Golden build for issue #106 build-spec corpus. Known-good, ERC-clean, simulates to the spec sim_assertion on ngspice.</description>
    <author>issue-106</author>
  </metadata>
  <nets>
    <net id="gnd" role="ground"/>
    <net id="v12" role="power" nominal_voltage="12V"/>
    <net id="gate_drive" role="digital_signal"/>
    <net id="motor_low" role="analog_signal"/>
  </nets>
  <components>
    <component id="V_12" type="voltage_source">
      <value>12V</value>
      <pin name="p" net="v12"/>
      <pin name="n" net="gnd"/>
    </component>
    <component id="R_MOTOR" type="resistor">
      <value>24</value>
      <pin name="1" net="v12"/>
      <pin name="2" net="motor_low"/>
    </component>
    <component id="D_FLY" type="diode" part="1N4148">
      <pin name="a" net="motor_low"/>
      <pin name="c" net="v12"/>
    </component>
    <component id="Q1" type="mosfet" part="BSS138">
      <pin name="G" net="gate_drive"/>
      <pin name="D" net="motor_low"/>
      <pin name="S" net="gnd"/>
    </component>
    <component id="U_MCU" type="mcu" part="STM32F103">
      <pin name="VDD" net="v12"/>
      <pin name="VSS" net="gnd"/>
      <pin name="PA0" net="gate_drive" function="GPIO"/>
    </component>
  </components>
  <firmware>
    <project id="fw_main" target="U_MCU" framework="platformio" language="cpp">
      <board>bluepill_f103c8</board>
      <source_tree path="firmware/"/>
    </project>
    <task id="drive" target="fw_main">
      <write_gpio pin="PA0" value="high"/>
    </task>
  </firmware>
  <analog>
    <subsystem id="s">
      <uses component="V_12"/>
      <uses component="R_MOTOR"/>
      <uses component="D_FLY"/>
      <uses component="Q1"/>
      <probe id="probe_motor_low" net="motor_low" quantity="voltage"/>
    </subsystem>
  </analog>
  <tests>
    <test id="t">
      <setup><set_voltage net="v12" value="12V"/></setup>
      <run duration="1ms"/>
      <assert_voltage net="motor_low" min="0.0V" max="0.5V"/>
    </test>
  </tests>
  <simulation_profiles>
    <profile id="analog_only" default="true">
      <backend type="ngspice"/>
      <include subsystem="s"/>
      <run test="t"/>
    </profile>
  </simulation_profiles>
</system>
