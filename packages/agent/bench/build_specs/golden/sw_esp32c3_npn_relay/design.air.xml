<system name="gt106_sw_esp32c3_npn_relay" ir_version="0.1">
  <metadata>
    <title>NPN relay</title>
    <description>Golden build for issue #106 build-spec corpus. Known-good, ERC-clean, simulates to the spec sim_assertion on ngspice.</description>
    <author>issue-106</author>
  </metadata>
  <nets>
    <net id="gnd" role="ground"/>
    <net id="v5" role="power" nominal_voltage="5V"/>
    <net id="base_drive" role="digital_signal"/>
    <net id="base" role="analog_signal"/>
    <net id="coil_low" role="analog_signal"/>
  </nets>
  <components>
    <component id="V_5" type="voltage_source">
      <value>5V</value>
      <pin name="p" net="v5"/>
      <pin name="n" net="gnd"/>
    </component>
    <component id="R_BASE" type="resistor">
      <value>1k</value>
      <pin name="1" net="base_drive"/>
      <pin name="2" net="base"/>
    </component>
    <component id="R_COIL" type="resistor">
      <value>120</value>
      <pin name="1" net="v5"/>
      <pin name="2" net="coil_low"/>
    </component>
    <component id="D_FLY" type="diode" part="1N4148">
      <pin name="a" net="coil_low"/>
      <pin name="c" net="v5"/>
    </component>
    <component id="Q1" type="bjt" part="2N2222">
      <pin name="C" net="coil_low"/>
      <pin name="B" net="base"/>
      <pin name="E" net="gnd"/>
    </component>
    <component id="U_MCU" type="mcu" part="ESP32-C3">
      <pin name="3V3" net="v5"/>
      <pin name="GND" net="gnd"/>
      <pin name="GPIO2" net="base_drive" function="GPIO_OUT"/>
    </component>
  </components>
  <firmware>
    <project id="fw_main" target="U_MCU" framework="platformio" language="cpp">
      <board>esp32-c3-devkitm-1</board>
      <source_tree path="firmware/"/>
    </project>
    <task id="drive" target="fw_main">
      <write_gpio pin="GPIO2" value="high"/>
    </task>
  </firmware>
  <analog>
    <subsystem id="s">
      <uses component="V_5"/>
      <uses component="R_BASE"/>
      <uses component="R_COIL"/>
      <uses component="D_FLY"/>
      <uses component="Q1"/>
      <probe id="probe_coil_low" net="coil_low" quantity="voltage"/>
    </subsystem>
  </analog>
  <tests>
    <test id="t">
      <setup><set_voltage net="v5" value="5V"/></setup>
      <run duration="1ms"/>
      <assert_voltage net="coil_low" min="0.0V" max="0.4V"/>
    </test>
  </tests>
  <simulation_profiles>
    <profile id="analog_only" default="true">
      <backend type="ngspice"/>
      <include subsystem="s"/>
      <run test="t"/>
    </profile>
  </simulation_profiles>
</system>
