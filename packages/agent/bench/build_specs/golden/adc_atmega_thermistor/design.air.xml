<system name="gt106_adc_atmega_thermistor" ir_version="0.1">
  <metadata>
    <title>Arduino thermistor</title>
    <description>Golden build for issue #106 build-spec corpus. Known-good, ERC-clean, simulates to the spec sim_assertion on ngspice.</description>
    <author>issue-106</author>
  </metadata>
  <nets>
    <net id="gnd" role="ground"/>
    <net id="vcc" role="power" nominal_voltage="5V"/>
    <net id="therm_sense" role="analog_signal"/>
  </nets>
  <components>
    <component id="V_CC" type="voltage_source">
      <value>5V</value>
      <pin name="p" net="vcc"/>
      <pin name="n" net="gnd"/>
    </component>
    <component id="R_THERM" type="resistor" part="NTC_10K_3977">
      <value>10k</value>
      <pin name="1" net="vcc"/>
      <pin name="2" net="therm_sense"/>
    </component>
    <component id="R_FIXED" type="resistor">
      <value>10k</value>
      <pin name="1" net="therm_sense"/>
      <pin name="2" net="gnd"/>
    </component>
    <component id="U_MCU" type="mcu" part="ATmega328P">
      <pin name="VCC" net="vcc"/>
      <pin name="GND" net="gnd"/>
      <pin name="A0" net="therm_sense" function="ADC1_CH0"/>
    </component>
  </components>
  <firmware>
    <project id="fw_main" target="U_MCU" framework="platformio" language="cpp">
      <board>uno</board>
      <source_tree path="firmware/"/>
    </project>
    <binding id="adc_binding">
      <signal name="sense"/>
      <component ref="U_MCU"/>
      <peripheral>ADC1</peripheral>
      <channel>ADC1_CH0</channel>
      <net>therm_sense</net>
    </binding>
    <task id="read_sense" target="fw_main">
      <period>1s</period>
      <read_adc binding="adc_binding" into="v_raw"/>
    </task>
  </firmware>
  <analog>
    <subsystem id="s">
      <uses component="V_CC"/>
      <uses component="R_THERM"/>
      <uses component="R_FIXED"/>
      <probe id="probe_therm_sense" net="therm_sense" quantity="voltage"/>
    </subsystem>
  </analog>
  <tests>
    <test id="t">
      <setup><set_voltage net="vcc" value="5V"/></setup>
      <run duration="1ms"/>
      <assert_voltage net="therm_sense" min="2.475V" max="2.525V"/>
    </test>
  </tests>
  <simulation_profiles>
    <profile id="analog_only" default="true">
      <backend type="ngspice"/>
      <include subsystem="s"/>
      <run test="t"/>
    </profile>
  </simulation_profiles>
</system>
