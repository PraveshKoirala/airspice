<system name="gt106_sw_atmega_bss138_lowside" ir_version="0.1">
  <metadata>
    <title>BSS138 low-side</title>
    <description>Golden build for issue #106 build-spec corpus. Known-good, ERC-clean, simulates to the spec sim_assertion on ngspice.</description>
    <author>issue-106</author>
  </metadata>
  <nets>
    <net id="gnd" role="ground"/>
    <net id="v5" role="power" nominal_voltage="5V"/>
    <net id="gate_drive" role="digital_signal"/>
    <net id="load_low" role="analog_signal"/>
  </nets>
  <components>
    <component id="V_5" type="voltage_source">
      <value>5V</value>
      <pin name="p" net="v5"/>
      <pin name="n" net="gnd"/>
    </component>
    <component id="R_LOAD" type="resistor">
      <value>50</value>
      <pin name="1" net="v5"/>
      <pin name="2" net="load_low"/>
    </component>
    <component id="Q1" type="mosfet" part="BSS138">
      <pin name="G" net="gate_drive"/>
      <pin name="D" net="load_low"/>
      <pin name="S" net="gnd"/>
    </component>
    <component id="U_MCU" type="mcu" part="ATmega328P">
      <pin name="VCC" net="v5"/>
      <pin name="GND" net="gnd"/>
      <pin name="D2" net="gate_drive" function="GPIO_OUT"/>
    </component>
  </components>
  <firmware>
    <project id="fw_main" target="U_MCU" framework="platformio" language="cpp">
      <board>uno</board>
      <source_tree path="firmware/"/>
    </project>
    <task id="drive" target="fw_main">
      <write_gpio pin="D2" value="high"/>
    </task>
  </firmware>
  <analog>
    <subsystem id="s">
      <uses component="V_5"/>
      <uses component="R_LOAD"/>
      <uses component="Q1"/>
      <probe id="probe_load_low" net="load_low" quantity="voltage"/>
    </subsystem>
  </analog>
  <tests>
    <test id="t">
      <setup><set_voltage net="v5" value="5V"/></setup>
      <run duration="1ms"/>
      <assert_voltage net="load_low" min="0.0V" max="0.3V"/>
    </test>
  </tests>
  <simulation_profiles>
    <profile id="analog_only" default="true">
      <backend type="ngspice"/>
      <include subsystem="s"/>
      <run test="t"/>
    </profile>
  </simulation_profiles>
</system>
