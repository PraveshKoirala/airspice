# The golden corpus is byte-compared in CI (`export_golden.py --check`). Windows
# devs must not churn it via CRLF autoconversion, so force LF for every corpus
# file regardless of core.autocrlf. The exporter also writes LF explicitly; this
# is the belt-and-suspenders half that survives checkout/clone.
tests/golden_corpus/** text eol=lf

# Corpus artifacts are generated, deterministic reference data -- keep them out of
# language stats and mark them as generated so review tooling collapses them.
tests/golden_corpus/** linguist-generated=true

# Guarantee LF line endings for files executed on Linux CI, so the bash `run:`
# blocks in workflows and the Python checker never carry a stray CR (\r) that
# would break shell execution or comparisons on ubuntu-latest.
*.yml   text eol=lf
*.yaml  text eol=lf
*.py    text eol=lf
*.sh    text eol=lf

# PowerShell scripts run on Windows; keep CRLF for them.
*.ps1   text eol=crlf

# The differential fuzzer (issue #43) archives byte-sensitive fixtures: shrunk
# reproducers whose recorded model hashes / rejection codes depend on exact
# bytes (a literal tab in an attribute value, a deep-nesting doc whose element
# count is checked, CR handling). Hostile XML-security fixtures are likewise
# byte-compared across BOTH engines. Force LF everywhere so a Windows checkout
# never rewrites a \n to \r\n and shifts a hash or a byte count. The fuzzer's
# own mjs script runs on Node on Linux CI, so it is LF too.
tests/fuzz_regressions/**  text eol=lf
tests/xml_security/**      text eol=lf
scripts/fuzz_diff.mjs      text eol=lf
# The sim-parity capture script (issue #15) runs on Node on Linux CI too.
scripts/sim_parity.mjs     text eol=lf
